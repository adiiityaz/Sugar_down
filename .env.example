# Copy to `.env` for local dev. Link your storefront:
#   npx shopify hydrogen link --storefront "Sugar Down"
# Or pull env from Shopify CLI after linking.

SESSION_SECRET=replace-with-at-least-32-characters-secret-key!!

# Populated by `shopify hydrogen link` / Shopify Admin → Headless channel
PUBLIC_STOREFRONT_API_TOKEN=
PUBLIC_STORE_DOMAIN=
PUBLIC_CHECKOUT_DOMAIN=
PUBLIC_STOREFRONT_ID=

# Customer Account API (account login, orders) — from Hydrogen admin; use dev with --customer-account-push and open the tunnel URL
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=
PUBLIC_CUSTOMER_ACCOUNT_API_URL=https://shopify.com/YOUR_NUMERIC_SHOP_ID
SHOP_ID=

# Paste https://….tryhydrogen.dev from the terminal after npm run dev (new URL each restart). Required for /account on localhost.
PUBLIC_DEV_TUNNEL_ORIGIN=
