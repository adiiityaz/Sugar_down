<script src="shared.js"></script>
<script>
const THUMBS={kwath:'background:linear-gradient(135deg,#1a5c30,#2e7d4f)',daycaps:'background:linear-gradient(135deg,#0d4a36,#1a8c5e)',sleepcaps:'background:linear-gradient(135deg,#1A3A5C,#2a5a8c)',corekit:'background:linear-gradient(135deg,#1B4D2E,#0d3320)',balkit:'background:linear-gradient(135deg,#0d4a36,#1a8c5e)'};
let selectedPay = 'upi';

function selectPay(el, type) {
  document.querySelectorAll('.pay-option').forEach(o=>o.classList.remove('selected'));
  el.classList.add('selected');
  selectedPay = type;
  document.querySelectorAll('.pay-details').forEach(d=>d.classList.remove('show'));
  document.getElementById('pay-'+type).classList.add('show');
}

function verifyUPI() {
  const v = document.getElementById('upi-id').value;
  const msg = document.getElementById('upi-msg');
  if (v.includes('@')) { msg.style.color='var(--gm)'; msg.textContent='✓ UPI ID looks valid'; }
  else { msg.style.color='var(--red)'; msg.textContent='✗ Invalid UPI ID format'; }
}

function formatCard(el) {
  let v = el.value.replace(/\s/g,'').replace(/\D/g,'');
  el.value = v.replace(/(.{4})/g,'$1 ').trim();
}

function renderSummary() {
  const cart = getCart();
  let html = '';
  const sub = cart.reduce((s,i)=>{ const p=PRODUCTS[i.id]; if(!p)return s; html+=`<div class="s-item"><div class="s-thumb" style="${THUMBS[i.id]||''}">${p.img}</div><div class="s-info"><div class="s-name">${p.name}</div><div class="s-qty">Qty: ${i.qty}</div></div><div class="s-price">₹${(p.price*i.qty).toLocaleString()}</div></div>`; return s+p.price*i.qty; },0);
  document.getElementById('s-items').innerHTML = html;
  
  // First add GST
  const gst = Math.round(sub*0.05);
  const withGst = sub+gst;
  
  // Then calculate discount (on subtotal + gst)
  const disc = Math.round(withGst*0.05);
  
  const total = withGst-disc;
  
  document.getElementById('s-sub').textContent='₹'+sub.toLocaleString();
  document.getElementById('s-disc').textContent='-₹'+disc.toLocaleString();
  document.getElementById('s-gst').textContent='₹'+gst.toLocaleString();
  document.getElementById('s-total').textContent='₹'+total.toLocaleString();
  localStorage.setItem('sd_order_total',total);
}

function validateForm() {
  const req = [{id:'fname',label:'First Name'},{id:'lname',label:'Last Name'},{id:'phone',label:'Mobile Number'},{id:'addr1',label:'Address'},{id:'addr2',label:'Street/Area'},{id:'city',label:'City'},{id:'state',label:'State'},{id:'pin',label:'PIN Code'}];
  for (const f of req) {
    const v = document.getElementById(f.id)?.value?.trim();
    if (!v) { alert('Please fill in: '+f.label); document.getElementById(f.id)?.focus(); return false; }
  }
  const pin = document.getElementById('pin').value;
  if (!/^\d{6}$/.test(pin)) { alert('Please enter a valid 6-digit PIN code'); return false; }
  const phone = document.getElementById('phone').value;
  if (!/^\+?[\d\s-]{10,}$/.test(phone)) { alert('Please enter a valid mobile number'); return false; }
  return true;
}

function placeOrder() {
  if (!validateForm()) return;
  const cart = getCart();
  if (cart.length === 0) { alert('Your cart is empty!'); return; }

  const overlay = document.getElementById('overlay');
  overlay.classList.add('show');

  // Save order details
  const orderId = generateOrderId();
  const orderData = {
    id: orderId,
    items: cart,
    name: document.getElementById('fname').value + ' ' + document.getElementById('lname').value,
    phone: document.getElementById('phone').value,
    address: [document.getElementById('addr1').value, document.getElementById('addr2').value, document.getElementById('city').value, document.getElementById('state').value, document.getElementById('pin').value].join(', '),
    payMethod: selectedPay,
    total: localStorage.getItem('sd_order_total'),
    date: new Date().toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}),
    status: 'confirmed'
  };
  localStorage.setItem('sd_last_order', JSON.stringify(orderData));
  localStorage.setItem('sd_order_'+orderId, JSON.stringify(orderData));

  setTimeout(() => {
    saveCart([]);
    window.location.href = 'confirmation.html';
  }, 2200);
}

renderSummary();
</script>
</body></html>

