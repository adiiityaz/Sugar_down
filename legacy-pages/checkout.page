<div class="overlay" id="overlay">
  <div class="spinner"></div>
  <h3>Placing Your Order...</h3>
  <p>Please don't close this window</p>
</div>

<div class="wrap">
  <div class="breadcrumb"><a href="index.html">Home</a> › <a href="cart.html">Cart</a> › Checkout</div>
  <h1 class="pg-title">Checkout</h1>

  <div class="steps-bar">
    <div class="step done"><div class="step-num">✓</div><span>Cart</span></div>
    <div class="step-line done"></div>
    <div class="step active"><div class="step-num">2</div><span>Checkout</span></div>
    <div class="step-line"></div>
    <div class="step pending"><div class="step-num">3</div><span>Confirmation</span></div>
  </div>

  <div class="checkout-layout">
    <div>
      <!-- CONTACT INFO -->
      <div class="csec">
        <div class="csec-title"><span>👤</span> Contact Information</div>
        <div class="form-row">
          <div class="form-group"><label>First Name *</label><input type="text" id="fname" placeholder="Ramesh" /></div>
          <div class="form-group"><label>Last Name *</label><input type="text" id="lname" placeholder="Sharma" /></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Mobile Number *</label><input type="tel" id="phone" placeholder="+91 98765 43210" /></div>
          <div class="form-group"><label>Email Address</label><input type="email" id="email" placeholder="you@example.com" /></div>
        </div>
      </div>

      <!-- DELIVERY ADDRESS -->
      <div class="csec">
        <div class="csec-title"><span>📍</span> Delivery Address</div>
        <div class="form-group"><label>Flat / House No. / Building *</label><input type="text" id="addr1" placeholder="Flat 202, Green Residency" /></div>
        <div class="form-group"><label>Street / Area / Locality *</label><input type="text" id="addr2" placeholder="Hazratganj, Near Civil Lines" /></div>
        <div class="form-row">
          <div class="form-group"><label>City *</label><input type="text" id="city" placeholder="Lucknow" /></div>
          <div class="form-group"><label>State *</label>
            <select id="state">
              <option value="">Select State</option>
              <option>Uttar Pradesh</option><option>Maharashtra</option><option>Delhi</option>
              <option>Gujarat</option><option>Rajasthan</option><option>Bihar</option>
              <option>Madhya Pradesh</option><option>Karnataka</option><option>Tamil Nadu</option>
              <option>West Bengal</option><option>Punjab</option><option>Haryana</option>
              <option>Andhra Pradesh</option><option>Telangana</option><option>Kerala</option>
              <option>Other</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>PIN Code *</label><input type="text" id="pin" placeholder="226001" maxlength="6" /></div>
          <div class="form-group"><label>Landmark (optional)</label><input type="text" id="landmark" placeholder="Near Apollo Hospital" /></div>
        </div>
      </div>

      <!-- PAYMENT -->
      <div class="csec">
        <div class="csec-title"><span>💳</span> Payment Method</div>
        <div class="pay-methods">
          <div class="pay-option selected" onclick="selectPay(this,'upi')">
            <div class="pay-radio"><div class="pay-radio-dot"></div></div>
            <span class="pay-icon">📱</span>
            <div class="pay-info"><div class="pay-name">UPI Payment</div><div class="pay-sub">GPay, PhonePe, Paytm, BHIM</div></div>
            <span class="pay-badge">Instant</span>
          </div>
          <div class="pay-option" onclick="selectPay(this,'card')">
            <div class="pay-radio"><div class="pay-radio-dot"></div></div>
            <span class="pay-icon">💳</span>
            <div class="pay-info"><div class="pay-name">Debit / Credit Card</div><div class="pay-sub">Visa, Mastercard, RuPay</div></div>
          </div>
          <div class="pay-option" onclick="selectPay(this,'cod')">
            <div class="pay-radio"><div class="pay-radio-dot"></div></div>
            <span class="pay-icon">💵</span>
            <div class="pay-info"><div class="pay-name">Cash on Delivery</div><div class="pay-sub">Pay when your order arrives</div></div>
            <span class="pay-badge">No Risk</span>
          </div>
        </div>

        <!-- UPI DETAILS -->
        <div class="pay-details show" id="pay-upi">
          <div style="font-size:13px;font-weight:600;margin-bottom:10px;">Enter your UPI ID</div>
          <div class="upi-input">
            <input type="text" placeholder="yourname@upi or mobile@paytm" id="upi-id" />
            <button class="upi-verify" onclick="verifyUPI()">Verify</button>
          </div>
          <div id="upi-msg" style="font-size:12px;margin-top:8px;min-height:16px;"></div>
          <div style="margin-top:14px;font-size:12px;color:var(--gray-l);">Or pay using QR code after placing order — our team will send it on WhatsApp.</div>
        </div>

        <!-- CARD DETAILS -->
        <div class="pay-details" id="pay-card">
          <div class="form-group"><label>Card Number</label><input type="text" placeholder="1234 5678 9012 3456" maxlength="19" id="card-num" oninput="formatCard(this)" /></div>
          <div class="card-grid">
            <div class="form-group"><label>Expiry Date</label><input type="text" placeholder="MM / YY" maxlength="7" /></div>
            <div class="form-group"><label>CVV</label><input type="password" placeholder="•••" maxlength="4" /></div>
          </div>
          <div class="form-group"><label>Name on Card</label><input type="text" placeholder="As printed on card" /></div>
        </div>

        <!-- COD DETAILS -->
        <div class="pay-details" id="pay-cod">
          <div class="cod-info">✅ <strong>Cash on Delivery available.</strong><br><br>Keep the exact amount ready when our delivery partner arrives. Our team will confirm your order on WhatsApp before dispatch.<br><br>Delivery in 3–5 working days. No advance payment needed.</div>
        </div>
