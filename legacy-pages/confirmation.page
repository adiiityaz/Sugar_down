<script>
const PAYMETHODS={upi:'UPI Payment',card:'Debit / Credit Card',cod:'Cash on Delivery'};
window.addEventListener('DOMContentLoaded',()=>{
  const o=JSON.parse(localStorage.getItem('sd_last_order')||'{}');
  if(o.id){document.getElementById('oid').textContent=o.id;document.getElementById('oname').textContent=o.name||'—';document.getElementById('ophone').textContent=o.phone||'—';document.getElementById('oaddr').textContent=o.address||'—';document.getElementById('opay').textContent=PAYMETHODS[o.payMethod]||o.payMethod||'—';document.getElementById('ototl').textContent='₹'+(parseInt(o.total)||0).toLocaleString();document.getElementById('odate').textContent=o.date||'—';}
});
