  <script>
    let currentIdx = 0;
    const cards = document.querySelectorAll('.review-stack-card');
    const dotsContainer = document.getElementById('slider-dots');

    // Create dots
    cards.forEach((_, i) => {
      const dot = document.createElement('div');
      dot.className = 'dot' + (i === 0 ? ' active' : '');
      dot.onclick = () => showReview(i);
      dotsContainer.appendChild(dot);
    });

    const dots = document.querySelectorAll('.dot');

    function showReview(idx) {
      const prevIdx = currentIdx;
      currentIdx = (idx + cards.length) % cards.length;

      // Reset all classes
      cards.forEach(card => {
        card.classList.remove('active', 'next-1', 'next-2', 'exit');
      });

      // Handle exit of previous card
      cards[prevIdx].classList.add('exit');
      setTimeout(() => {
        cards[prevIdx].classList.remove('exit');
      }, 600);

      // Assign stack classes
      cards[currentIdx].classList.add('active');
      
      const next1Idx = (currentIdx + 1) % cards.length;
      const next2Idx = (currentIdx + 2) % cards.length;
      
      cards[next1Idx].classList.add('next-1');
      cards[next2Idx].classList.add('next-2');

      // Update dots
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === currentIdx);
      });
    }

    // Auto-init stack for first load
    window.addEventListener('DOMContentLoaded', () => {
      showReview(0);
    });

    function nextReview() { showReview(currentIdx + 1); }
    function prevReview() { showReview(currentIdx - 1); }

  </script>

