<script>
const STATUS_FLOW = {
  confirmed: {label:'Order Confirmed', badge:'status-confirmed'},
  packed:    {label:'Packed & Ready', badge:'status-packed'},
  shipped:   {label:'Shipped', badge:'status-shipped'},
  delivered: {label:'Delivered', badge:'status-delivered'}
};

const TIMELINE_STEPS = [
  {key:'confirmed', icon:'✓', title:'Order Confirmed', desc:'Your order has been received and confirmed. Our team has been notified.'},
  {key:'packed',   icon:'📦', title:'Order Packed', desc:'Your Sugar Down kit has been carefully packed and is ready for dispatch.'},
  {key:'shipped',  icon:'🚚', title:'Shipped', desc:'Your order is on the way! Track via the courier link sent on WhatsApp.'},
  {key:'delivered',icon:'🏠', title:'Delivered', desc:'Your order has been delivered. Enjoy your Sugar Down journey! 🌿'},
];

function getStatusIndex(status) {
  const order = ['confirmed','packed','shipped','delivered'];
  return order.indexOf(status);
}

function renderTimeline(status) {
  const current = getStatusIndex(status);
  let html = '';
  TIMELINE_STEPS.forEach((s, i) => {
    const state = i < current ? 'done' : (i === current ? 'active' : 'pending');
    const time = i <= current ? (i===0?'Just now': i===1?'Within 24 hrs': i===2?'1-2 days': '3-5 days') : 'Pending';
    html += `<div class="tl-step">
      <div class="tl-dot ${state}">${state==='done'?'✓':s.icon}</div>
      <div class="tl-title ${state==='pending'?'pending-text':''}">${s.title}</div>
      <div class="tl-time">${time}</div>
      ${state!=='pending'?`<div class="tl-desc">${s.desc}</div>`:''}
    </div>`;
  });
  document.getElementById('timeline').innerHTML = html;
}

function trackOrder() {
  const id = document.getElementById('track-input').value.trim().toUpperCase();
  if (!id) { alert('Please enter your Order ID'); return; }

  document.getElementById('result-box').style.display = 'none';
  document.getElementById('not-found').style.display = 'none';

  const order = JSON.parse(localStorage.getItem('sd_order_'+id) || 'null');

  if (order) {
    showOrder(order);
  } else if (id.startsWith('SD') && id.length >= 8) {
    // Demo order for any valid-looking ID
    const demoOrder = {id, name:'Customer', phone:'—', address:'India', payMethod:'cod', total:'1755', date: new Date().toLocaleDateString('en-IN'), status:'shipped'};
    showOrder(demoOrder);
  } else {
    document.getElementById('not-found').style.display = 'block';
  }
}

function showOrder(order) {
  const box = document.getElementById('result-box');
  box.style.display = 'block';
  document.getElementById('r-id').textContent = order.id;
  document.getElementById('r-date').textContent = 'Ordered on ' + (order.date||'—');
  document.getElementById('r-name').textContent = order.name||'—';
  document.getElementById('r-phone').textContent = order.phone||'—';
  document.getElementById('r-addr').textContent = order.address||'—';
  document.getElementById('r-total').textContent = '₹'+(parseInt(order.total)||0).toLocaleString();

  const status = order.status || 'confirmed';
  const sf = STATUS_FLOW[status] || STATUS_FLOW.confirmed;
  const badge = document.getElementById('r-status-badge');
  badge.textContent = sf.label;
  badge.className = 'status-badge ' + sf.badge;
  renderTimeline(status);
}

// Show recent orders
window.addEventListener('DOMContentLoaded', () => {
  const lastOrder = JSON.parse(localStorage.getItem('sd_last_order')||'null');
  if (lastOrder) {
    document.getElementById('recent-box').style.display = 'block';
    document.getElementById('recent-list').innerHTML = `<div class="recent-item" onclick="document.getElementById('track-input').value='${lastOrder.id}';trackOrder()"><span class="recent-id">${lastOrder.id}</span><span class="recent-date">${lastOrder.date||''}</span><span class="recent-arrow">→</span></div>`;
  }
});
</script>
