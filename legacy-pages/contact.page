<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Contact Us — Sugar Down</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

</head>
<body>
<nav>
  <a href="index.html" class="nl"><span>SUGAR DOWN</span><span>BY LUCKY HEART AYURVEDA</span></a>
  <ul class="nm"><li><a href="index.html">Home</a></li><li><a href="products.html">Products</a></li><li><a href="about.html">About</a></li><li><a href="contact.html" class="act">Contact</a></li></ul>
  <a href="products.html" class="nc">Shop Now</a>
</nav>

<div class="hero">
  <h1>We're Always Here For You</h1>
  <p>Questions, concerns or just want to know if Sugar Down is right for you — reach out anytime.</p>
</div>

<div class="wrap">
  <div class="wa-banner">
    <div class="wa-banner-left"><h3>Fastest Response on WhatsApp</h3><p>Average reply time: under 5 minutes. Available 24×7.</p></div>
    <a href="https://wa.me/91XXXXXXXXXX?text=Hello!%20I%20want%20to%20know%20more%20about%20Sugar%20Down" class="wa-btn">💬 Chat on WhatsApp Now</a>
  </div>

  <div class="contact-layout">
    <div>
      <div class="channels">
        <a href="https://wa.me/91XXXXXXXXXX" class="channel-card">
          <div class="ch-icon ch-wa">💬</div>
          <div><div class="ch-label">Fastest</div><div class="ch-name">WhatsApp Support</div><div class="ch-val">+91-XXXXXXXXXX</div><div class="ch-sub">24×7 · Usually replies in under 5 mins</div></div>
        </a>
        <a href="tel:+91XXXXXXXXXX" class="channel-card">
          <div class="ch-icon ch-ph">📞</div>
          <div><div class="ch-label">Call Us</div><div class="ch-name">Phone Support</div><div class="ch-val">+91-XXXXXXXXXX</div><div class="ch-sub">Mon–Sat · 9:00 AM – 8:00 PM</div></div>
        </a>
        <a href="mailto:support@sugardown.in" class="channel-card">
          <div class="ch-icon ch-em">✉️</div>
          <div><div class="ch-label">Email Us</div><div class="ch-name">Email Support</div><div class="ch-val">support@sugardown.in</div><div class="ch-sub">Reply within 4–6 business hours</div></div>
        </a>
      </div>
      <div class="hours-card">
        <h4>Support Hours</h4>
        <div class="hour-row"><span>WhatsApp</span><span>24×7 Always Open</span></div>
        <div class="hour-row"><span>Phone Calls</span><span>9 AM – 8 PM</span></div>
        <div class="hour-row"><span>Email</span><span>Mon – Sat</span></div>
        <div class="hour-row"><span>Follow-up Calls</span><span>Daily for all customers</span></div>
      </div>

      <div class="faq-mini" style="margin-top:28px;">
        <h3>Quick Answers</h3>
        <div class="fitem"><div class="fq">How do I order? <span>+</span></div><div class="fa">Simply WhatsApp us or click "Order Now" on the website. Share your address, choose your kit, and we'll confirm within 30 minutes.</div></div>
        <div class="fitem"><div class="fq">When will I get my order? <span>+</span></div><div class="fa">Orders are shipped within 24 hours and delivered in 3–5 working days across India. You'll receive tracking updates on WhatsApp.</div></div>
        <div class="fitem"><div class="fq">Is there a return policy? <span>+</span></div><div class="fa">If you receive a damaged or wrong product, contact us within 48 hours and we will replace it immediately. WhatsApp us a photo of the product.</div></div>
      </div>
    </div>

    <div class="form-card">
      <h3>Send Us a Message</h3>
      <p>Fill this form and we'll reply on WhatsApp within 30 minutes.</p>
      <div class="form-row">
        <div class="form-group"><label>Your Name *</label><input type="text" id="cf-name" placeholder="Ramesh Sharma" /></div>
        <div class="form-group"><label>Mobile Number *</label><input type="tel" id="cf-phone" placeholder="+91 98765 43210" /></div>
      </div>
      <div class="form-group"><label>Email</label><input type="email" id="cf-email" placeholder="you@email.com" /></div>
      <div class="form-group"><label>Subject *</label>
        <select id="cf-subject">
          <option value="">Select a topic</option>
          <option>Want to know more about Sugar Down</option>
          <option>Question about ingredients</option>
          <option>Order related query</option>
          <option>Delivery / tracking issue</option>
          <option>Diet plan support</option>
          <option>Product feedback</option>
          <option>Other</option>
        </select>
      </div>
      <div class="form-group"><label>Message *</label><textarea id="cf-message" placeholder="Tell us how we can help you..."></textarea></div>
      <button class="submit-btn" onclick="submitForm()">Send Message →</button>
      <div class="success-msg" id="cf-success">✓ Message received! We'll reply on WhatsApp within 30 minutes. 🙏</div>
    </div>
  </div>
</div>

<footer>
  <div class="fbrand"><span>SUGAR DOWN</span><p>By Lucky Heart Ayurveda · Complete Diabetes Care</p></div>
  <div class="flinks"><a href="index.html">Home</a><a href="products.html">Products</a><a href="about.html">About</a><a href="track.html">Track Order</a></div>
  <div class="fcopy">© 2025 Lucky Heart Ayurveda. All rights reserved.</div>
</footer>
<script>
function submitForm(){
  const n=document.getElementById('cf-name').value.trim();
  const p=document.getElementById('cf-phone').value.trim();
  const s=document.getElementById('cf-subject').value;
  const m=document.getElementById('cf-message').value.trim();
  if(!n||!p||!s||!m){alert('Please fill all required fields.');return;}
  document.getElementById('cf-success').style.display='block';
  document.querySelector('.submit-btn').textContent='✓ Sent!';
  document.querySelector('.submit-btn').style.background='var(--ga)';
}
document.querySelectorAll('.fq').forEach(q=>{q.addEventListener('click',()=>{const i=q.parentElement;const w=i.classList.contains('open');document.querySelectorAll('.fitem').forEach(x=>x.classList.remove('open'));if(!w)i.classList.add('open');});});
</script>
</body></html>

